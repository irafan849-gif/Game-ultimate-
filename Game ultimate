<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GameZone India — Gaming & Tech Blog</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0b0e14;
  --surface:#12161f;
  --card:#161b26;
  --border:#1e2535;
  --accent:#00d4ff;
  --accent2:#ff6b35;
  --green:#00e676;
  --text:#e8eaf0;
  --muted:#7a8499;
  --white:#ffffff;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans',sans-serif;font-size:15px;line-height:1.6;min-height:100vh}

/* === SCROLLBAR === */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--accent);border-radius:3px}

/* === HEADER === */
header{
  background:rgba(11,14,20,0.97);
  border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:100;
  backdrop-filter:blur(12px);
}
.header-inner{
  max-width:1200px;margin:0 auto;
  padding:0 20px;height:62px;
  display:flex;align-items:center;justify-content:space-between;
}
.logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:28px;letter-spacing:3px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  text-decoration:none;
}
.logo span{color:var(--accent2);-webkit-text-fill-color:var(--accent2)}
nav{display:flex;align-items:center;gap:4px}
nav a{
  color:var(--muted);text-decoration:none;
  padding:7px 14px;border-radius:6px;
  font-size:13px;font-weight:600;letter-spacing:0.5px;
  transition:all 0.2s;
}
nav a:hover{color:var(--text);background:rgba(255,255,255,0.05)}
nav a.active{color:var(--accent);background:rgba(0,212,255,0.08)}
.nav-cta{
  background:linear-gradient(135deg,var(--accent),#0099bb) !important;
  color:#000 !important;-webkit-text-fill-color:#000 !important;
  font-weight:700 !important;padding:7px 18px !important;
}
.nav-cta:hover{opacity:0.9;transform:translateY(-1px)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px}
.hamburger span{width:22px;height:2px;background:var(--text);border-radius:2px;transition:0.3s}

/* === AD BANNER TOP === */
.ad-banner{
  background:linear-gradient(135deg,rgba(0,212,255,0.06),rgba(255,107,53,0.06));
  border-bottom:1px solid var(--border);
  text-align:center;padding:10px;
  font-size:11px;color:var(--muted);letter-spacing:1px;
}
.ad-placeholder{
  display:inline-block;
  background:rgba(255,255,255,0.03);
  border:1px dashed rgba(255,255,255,0.1);
  border-radius:6px;padding:12px 40px;
  font-size:11px;color:var(--muted);letter-spacing:2px;
}

/* === HERO === */
.hero{
  max-width:1200px;margin:0 auto;padding:40px 20px 30px;
  display:grid;grid-template-columns:1fr 340px;gap:24px;
}
.hero-main{
  background:var(--card);border:1px solid var(--border);
  border-radius:14px;overflow:hidden;position:relative;cursor:pointer;
  transition:transform 0.3s;
}
.hero-main:hover{transform:translateY(-3px)}
.hero-img{
  width:100%;height:340px;object-fit:cover;
  background:linear-gradient(135deg,#0d1a2a,#1a0d2a,#0d2a1a);
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
.hero-img-content{
  text-align:center;position:relative;z-index:2;
}
.hero-img-icon{font-size:80px;display:block;margin-bottom:10px;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.hero-img::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 30% 50%,rgba(0,212,255,0.15),transparent 60%),
             radial-gradient(ellipse at 70% 50%,rgba(255,107,53,0.12),transparent 60%);
}
.grid-lines{
  position:absolute;inset:0;opacity:0.15;
  background-image:linear-gradient(rgba(0,212,255,0.3) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(0,212,255,0.3) 1px,transparent 1px);
  background-size:40px 40px;
}
.hero-badge{
  position:absolute;top:16px;left:16px;z-index:3;
  background:var(--accent2);color:#fff;
  font-size:10px;font-weight:700;letter-spacing:2px;
  padding:4px 12px;border-radius:20px;text-transform:uppercase;
}
.hero-content{padding:22px}
.hero-tag{
  display:inline-block;background:rgba(0,212,255,0.1);
  border:1px solid rgba(0,212,255,0.2);
  color:var(--accent);font-size:11px;font-weight:700;
  letter-spacing:2px;padding:3px 10px;border-radius:4px;
  text-transform:uppercase;margin-bottom:10px;
}
.hero-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:30px;letter-spacing:1px;line-height:1.15;
  color:var(--white);margin-bottom:10px;
}
.hero-excerpt{color:var(--muted);font-size:14px;line-height:1.6;margin-bottom:16px}
.hero-meta{display:flex;align-items:center;gap:16px;font-size:12px;color:var(--muted)}
.hero-meta .author{color:var(--accent);font-weight:600}
.read-btn{
  display:inline-flex;align-items:center;gap:8px;
  background:transparent;border:1px solid var(--accent);
  color:var(--accent);padding:9px 20px;border-radius:7px;
  font-size:13px;font-weight:600;cursor:pointer;
  transition:all 0.2s;text-decoration:none;margin-top:12px;
}
.read-btn:hover{background:var(--accent);color:#000}

/* HERO SIDEBAR */
.hero-side{display:flex;flex-direction:column;gap:12px}
.side-post{
  background:var(--card);border:1px solid var(--border);
  border-radius:10px;padding:16px;cursor:pointer;
  display:flex;gap:14px;align-items:flex-start;
  transition:all 0.2s;
}
.side-post:hover{border-color:rgba(0,212,255,0.3);background:rgba(0,212,255,0.03)}
.side-thumb{
  width:70px;height:70px;flex-shrink:0;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:28px;
}
.side-thumb.blue{background:linear-gradient(135deg,#0d1a2a,#0d2040)}
.side-thumb.orange{background:linear-gradient(135deg,#2a1a0d,#2a200d)}
.side-thumb.green{background:linear-gradient(135deg,#0d2a0d,#0d2020)}
.side-thumb.purple{background:linear-gradient(135deg,#1a0d2a,#200d2a)}
.side-info{}
.side-tag{font-size:10px;color:var(--accent2);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px}
.side-title{font-size:13px;font-weight:700;color:var(--text);line-height:1.4;margin-bottom:5px}
.side-meta{font-size:11px;color:var(--muted)}

/* === MAIN LAYOUT === */
.main-wrap{max-width:1200px;margin:0 auto;padding:0 20px 60px;display:grid;grid-template-columns:1fr 300px;gap:28px}

/* === SECTION HEADER === */
.section-head{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:18px;padding-bottom:12px;
  border-bottom:1px solid var(--border);
}
.section-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:22px;letter-spacing:2px;color:var(--white);
  display:flex;align-items:center;gap:10px;
}
.section-title::before{content:'';width:4px;height:22px;background:var(--accent);border-radius:2px;display:block}
.see-all{font-size:12px;color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:1px}
.see-all:hover{text-decoration:underline}

/* === POSTS GRID === */
.posts-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px}
.post-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;overflow:hidden;cursor:pointer;
  transition:all 0.25s;
}
.post-card:hover{transform:translateY(-4px);border-color:rgba(0,212,255,0.25);box-shadow:0 12px 40px rgba(0,0,0,0.4)}
.post-thumb{
  height:160px;display:flex;align-items:center;justify-content:center;
  font-size:50px;position:relative;overflow:hidden;
}
.post-thumb.t1{background:linear-gradient(135deg,#0d1f2a,#0a1520)}
.post-thumb.t2{background:linear-gradient(135deg,#2a1a0d,#1f1008)}
.post-thumb.t3{background:linear-gradient(135deg,#0a2a0a,#081508)}
.post-thumb.t4{background:linear-gradient(135deg,#1a0d2a,#120820)}
.post-thumb.t5{background:linear-gradient(135deg,#2a2a0d,#1f1f08)}
.post-thumb.t6{background:linear-gradient(135deg,#0d2a2a,#081f1f)}
.post-thumb::after{content:'';position:absolute;inset:0;background:linear-gradient(0deg,rgba(22,27,38,0.6),transparent)}
.post-label{
  position:absolute;top:10px;left:10px;z-index:2;
  font-size:10px;font-weight:700;letter-spacing:1.5px;
  padding:3px 9px;border-radius:4px;text-transform:uppercase;
}
.label-gaming{background:rgba(255,107,53,0.85);color:#fff}
.label-tech{background:rgba(0,212,255,0.85);color:#000}
.label-review{background:rgba(0,230,118,0.85);color:#000}
.label-tips{background:rgba(180,100,255,0.85);color:#fff}
.post-body{padding:16px}
.post-title{font-size:15px;font-weight:700;color:var(--text);line-height:1.4;margin-bottom:8px}
.post-excerpt{font-size:12px;color:var(--muted);line-height:1.5;margin-bottom:12px}
.post-footer{display:flex;align-items:center;justify-content:space-between;font-size:11px;color:var(--muted)}
.post-views{color:var(--accent);font-weight:600}

/* === AD SIDEBAR BOX === */
.ad-box{
  background:var(--card);border:1px solid var(--border);
  border-radius:10px;padding:20px;text-align:center;
  margin-bottom:20px;
}
.ad-box .ad-lbl{font-size:10px;color:var(--muted);letter-spacing:2px;margin-bottom:10px;display:block}
.ad-slot{
  background:rgba(255,255,255,0.02);
  border:1px dashed rgba(255,255,255,0.08);
  border-radius:6px;padding:40px 10px;
  font-size:11px;color:rgba(255,255,255,0.2);letter-spacing:2px;
}
.ad-slot.tall{padding:80px 10px}

/* === SIDEBAR === */
.sidebar{}
.sidebar-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;overflow:hidden;margin-bottom:20px;
}
.sidebar-head{
  padding:14px 16px;border-bottom:1px solid var(--border);
  font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:2px;
  color:var(--white);display:flex;align-items:center;gap:8px;
}
.trending-list{padding:8px 0}
.trending-item{
  padding:10px 16px;border-bottom:1px solid rgba(255,255,255,0.04);
  cursor:pointer;transition:background 0.2s;display:flex;gap:12px;align-items:flex-start;
}
.trending-item:last-child{border:none}
.trending-item:hover{background:rgba(255,255,255,0.03)}
.trend-num{
  font-family:'Bebas Neue',sans-serif;font-size:22px;
  color:rgba(0,212,255,0.2);line-height:1;flex-shrink:0;width:24px;
}
.trend-title{font-size:13px;font-weight:600;color:var(--text);line-height:1.4;margin-bottom:3px}
.trend-meta{font-size:11px;color:var(--muted)}

/* TAGS */
.tags-wrap{padding:14px 16px;display:flex;flex-wrap:wrap;gap:7px}
.tag{
  background:rgba(255,255,255,0.04);border:1px solid var(--border);
  border-radius:20px;padding:4px 12px;font-size:12px;color:var(--muted);
  cursor:pointer;transition:all 0.2s;
}
.tag:hover{border-color:var(--accent);color:var(--accent)}

/* NEWSLETTER */
.newsletter{padding:20px}
.newsletter p{font-size:13px;color:var(--muted);margin-bottom:14px;line-height:1.5}
.newsletter input{
  width:100%;background:rgba(255,255,255,0.05);
  border:1px solid var(--border);border-radius:7px;
  padding:10px 14px;color:var(--text);font-family:'Noto Sans',sans-serif;
  font-size:13px;margin-bottom:8px;outline:none;transition:border-color 0.2s;
}
.newsletter input:focus{border-color:var(--accent)}
.newsletter input::placeholder{color:var(--muted)}
.sub-btn{
  width:100%;background:linear-gradient(135deg,var(--accent),#0099bb);
  border:none;border-radius:7px;padding:11px;
  color:#000;font-weight:700;font-size:13px;letter-spacing:1px;
  cursor:pointer;transition:opacity 0.2s;
}
.sub-btn:hover{opacity:0.85}

/* === CATEGORIES SECTION === */
.cats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:32px}
.cat-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:10px;padding:20px 14px;text-align:center;
  cursor:pointer;transition:all 0.2s;
}
.cat-card:hover{border-color:rgba(0,212,255,0.3);transform:translateY(-2px)}
.cat-icon{font-size:30px;margin-bottom:8px;display:block}
.cat-name{font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px}
.cat-count{font-size:11px;color:var(--muted)}

/* === REVIEW SECTION === */
.review-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:20px;display:flex;gap:20px;
  margin-bottom:14px;cursor:pointer;transition:all 0.25s;
}
.review-card:hover{border-color:rgba(0,230,118,0.3);transform:translateX(4px)}
.review-icon{font-size:48px;flex-shrink:0;width:80px;height:80px;display:flex;align-items:center;justify-content:center;border-radius:10px;background:rgba(255,255,255,0.04)}
.review-info{flex:1}
.review-name{font-size:16px;font-weight:700;color:var(--white);margin-bottom:4px}
.review-sub{font-size:12px;color:var(--muted);margin-bottom:8px}
.stars{color:#ffd700;font-size:14px;margin-bottom:6px}
.review-verdict{
  display:inline-block;background:rgba(0,230,118,0.1);
  border:1px solid rgba(0,230,118,0.2);
  color:var(--green);font-size:11px;font-weight:700;
  letter-spacing:1px;padding:2px 10px;border-radius:4px;
}
.score-badge{
  font-family:'Bebas Neue',sans-serif;font-size:36px;
  color:var(--green);line-height:1;flex-shrink:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.score-badge span{font-size:11px;color:var(--muted);font-family:'Noto Sans',sans-serif;font-weight:400;letter-spacing:1px}

/* === TICKER === */
.ticker-wrap{
  background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  padding:8px 0;overflow:hidden;margin-bottom:30px;
}
.ticker{
  display:flex;gap:50px;animation:tickerMove 25s linear infinite;
  width:max-content;
}
@keyframes tickerMove{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.ticker-item{
  font-size:12px;color:var(--muted);white-space:nowrap;
  display:flex;align-items:center;gap:8px;
}
.ticker-item .dot{width:5px;height:5px;background:var(--accent);border-radius:50%;flex-shrink:0}
.ticker-item strong{color:var(--text)}

/* === FOOTER === */
footer{
  background:var(--surface);border-top:1px solid var(--border);
  padding:40px 20px 20px;
}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:32px;margin-bottom:30px}
.footer-brand .logo{font-size:24px;display:block;margin-bottom:10px}
.footer-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:16px}
.social-links{display:flex;gap:8px}
.social-btn{
  width:34px;height:34px;background:rgba(255,255,255,0.05);
  border:1px solid var(--border);border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;cursor:pointer;transition:all 0.2s;text-decoration:none;
}
.social-btn:hover{background:var(--accent);border-color:var(--accent)}
.footer-col h4{font-size:13px;font-weight:700;letter-spacing:2px;color:var(--white);margin-bottom:14px;text-transform:uppercase}
.footer-col a{display:block;font-size:13px;color:var(--muted);text-decoration:none;margin-bottom:8px;transition:color 0.2s}
.footer-col a:hover{color:var(--accent)}
.footer-bottom{
  padding-top:20px;border-top:1px solid var(--border);
  display:flex;justify-content:space-between;align-items:center;
  font-size:12px;color:var(--muted);
}
.footer-bottom a{color:var(--accent);text-decoration:none}

/* === MOBILE === */
@media(max-width:768px){
  nav{display:none}
  nav.open{display:flex;flex-direction:column;position:absolute;top:62px;left:0;right:0;background:var(--surface);border-bottom:1px solid var(--border);padding:10px}
  .hamburger{display:flex}
  .hero{grid-template-columns:1fr}
  .hero-side{display:none}
  .main-wrap{grid-template-columns:1fr}
  .posts-grid{grid-template-columns:1fr}
  .cats-grid{grid-template-columns:1fr 1fr}
  .footer-grid{grid-template-columns:1fr 1fr}
  .review-card{flex-wrap:wrap}
  .footer-bottom{flex-direction:column;gap:8px;text-align:center}
}
@media(max-width:480px){
  .hero-img{height:220px}
  .hero-img-icon{font-size:56px}
  .cats-grid{grid-template-columns:1fr 1fr}
  .footer-grid{grid-template-columns:1fr}
}

/* === ANIMATIONS === */
.fade-in{opacity:0;transform:translateY(20px);animation:fadeIn 0.6s forwards}
@keyframes fadeIn{to{opacity:1;transform:translateY(0)}}
.fade-in:nth-child(1){animation-delay:0.1s}
.fade-in:nth-child(2){animation-delay:0.2s}
.fade-in:nth-child(3){animation-delay:0.3s}
.fade-in:nth-child(4){animation-delay:0.4s}
</style>
</head>
